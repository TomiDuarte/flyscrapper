# Copiá este archivo a .env para desarrollo local. En GitHub Actions estos
# valores se cargan como Secrets (no subas .env al repo).

# --- Alertas: WhatsApp vía CallMeBot ---------------------------------------
# Teléfono en formato internacional, con + y código de país (ej: +595981123456)
CALLMEBOT_PHONE=+595981123456
# API key que te da el bot de CallMeBot al activarlo (ver README)
CALLMEBOT_APIKEY=123456

# Canal de alerta: "callmebot" (default) o "telegram"
ALERT_BACKEND=callmebot

# --- Alertas: Telegram (alternativa, opcional) -----------------------------
# TELEGRAM_TOKEN=123456:ABC-DEF...
# TELEGRAM_CHAT_ID=123456789

# --- Fuente de datos -------------------------------------------------------
# fast-flights fetch_mode: common | fallback | force-fallback | local
# En CI usar "local" (Playwright instalado). En tu PC sin navegador, "fallback".
FETCH_MODE=fallback

# Fallback opcional. Si está presente, se activa SerpApi (engine=google_flights).
# Dejar vacío para no usarlo.
SERPAPI_KEY=

# --- Almacenamiento --------------------------------------------------------
DB_PATH=data/precios.db
CACHE_PATH=data/cache_dryrun.json

# --- Opcionales ------------------------------------------------------------
# MONEDA=USD
# ADULTOS=1
# SEAT=economy
# MAX_REINTENTOS=3
# BACKOFF_BASE=3.0
# SLEEP_ENTRE_RUTAS=6.0
# ALERTAR_SI_LOW=1
# LOG_LEVEL=INFO
